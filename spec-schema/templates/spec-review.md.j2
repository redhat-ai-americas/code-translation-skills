{% endif %}

## Elements

{#- Group elements by hierarchy level. #}
{%- set hierarchy_order = ["system", "subsystem", "module", "class", "function"] -%}
{%- for level in hierarchy_order %}
{%- set level_elements = [] -%}
{%- for eid, el in elements.items() if el.hierarchy_level == level -%}
  {%- if level_elements.append((eid, el)) -%}{%- endif -%}
{%- endfor %}
{%- if level_elements %}

### {{ level | capitalize }}{% if level == "class" %}es{% else %}s{% endif %}

